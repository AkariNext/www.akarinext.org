HOST=0.0.0.0
PORT=1337
APP_KEYS="toBeModified1,toBeModified2"
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified
ENCRYPTION_KEY=tobemodified

# Database
# PostgreSQL: DATABASE_URL を設定すると自動で postgres を使用（Windows では SQLite のネイティブビルド不要）
# DATABASE_URL=postgres://user:password@localhost:5432/strapi
#
# SQLite（DATABASE_URL 未設定時）: Windows でエラーになる場合は「pnpm rebuild better-sqlite3」を試すか、上記で Postgres を使用
# DATABASE_CLIENT=sqlite
# DATABASE_FILENAME=.tmp/data.db
